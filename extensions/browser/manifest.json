{
  "manifest_version": 3,
  "name": "MangaLens",
  "version": "0.2.0",
  "description": "Translate manga, manhwa & manhua pages in-place while browsing. Supports Naver Webtoon, Kakao Page, and more.",
  "permissions": ["activeTab", "storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://comic.naver.com/*",
        "*://www.webtoons.com/*",
        "*://page.kakao.com/*",
        "*://mangadex.org/*",
        "*://mangaplus.shueisha.co.jp/*",
        "*://rawdevart.com/*",
        "*://raw.senmanga.com/*",
        "*://lezhin.com/*",
        "*://toomics.com/*",
        "*://tappytoon.com/*",
        "*://tapas.io/*",
        "*://www.mangago.me/*",
        "*://manganato.com/*",
        "*://chapmanganato.to/*",
        "*://readmanganato.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "exclude_matches": [
        "*://comic.naver.com/*",
        "*://www.webtoons.com/*",
        "*://page.kakao.com/*",
        "*://mangadex.org/*",
        "*://mangaplus.shueisha.co.jp/*",
        "*://rawdevart.com/*",
        "*://raw.senmanga.com/*",
        "*://lezhin.com/*",
        "*://toomics.com/*",
        "*://tappytoon.com/*",
        "*://tapas.io/*",
        "*://www.mangago.me/*",
        "*://manganato.com/*",
        "*://chapmanganato.to/*",
        "*://readmanganato.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
