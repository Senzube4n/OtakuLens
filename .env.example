# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./data/mangalens.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/mangalens

# Translation
CLAUDE_MODEL=claude-sonnet-4-20250514
DEFAULT_SOURCE_LANG=ko
DEFAULT_TARGET_LANG=en

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# Auto-download interval (minutes)
AUTO_DOWNLOAD_INTERVAL_MINUTES=30

# MCP Server
MCP_PORT=8001
